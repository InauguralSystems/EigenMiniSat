        "phase_neg_decisions": 0,
        "minimize_checks": 0,
        "minimize_removed": 0,
        "minimize_steps": 0
    }

define solve_cnf_cdcl(nvars, input_clauses) as:
    return solve_cnf_cdcl_with_options of [nvars, input_clauses, null]

define solve_cnf_cdcl_with_options(nvars, input_clauses, opts) as:
    local store is clause_store_from_clauses of input_clauses
    local stats is cdcl_empty_stats of null
    local asg is make_assignment of nvars
    local state is build_cdcl_state of [nvars, store, asg, stats, opts]

    if state.ok == 0:
        return cdcl_result of ["UNSAT", null, stats, state]

    loop while 1:
        if (run_watched_queue_cdcl of [nvars, store, asg, state, stats]) == 0:
            if (len of state.trail_lim) == 0:
                return cdcl_result of ["UNSAT", null, stats, state]

            bump_clause_db_activity of [state, state.conflict, stats]
            decay_clause_activity of [state, stats]
            state.conflicts_since_restart += 1
            local analysis is analyze_conflict_cdcl of [store, state, state.conflict, stats]
            if (len of analysis.clause) == 0:
                return cdcl_result of ["UNSAT", null, stats, state]

            if (len of analysis.clause) > 1:
                local min_seen is analysis.seen
                int_vector_fill of [min_seen, 0]
                for min_lit in analysis.clause:
                    min_seen[lit_abs of min_lit] is 1
                analysis.clause is minimize_clause of [analysis.clause, min_seen, state, store, stats]
                analysis.backtrack is max_clause_level_except of [analysis.clause, state, analysis.assert_lit]

            bump_clause_activity of [state, analysis.clause, stats]
            decay_var_activity of [state, stats]
            local learned_ci is add_cdcl_clause of [store, state, analysis.clause, 1, stats]
            bump_clause_db_activity of [state, learned_ci, stats]
            stats.learnts += 1
            cdcl_cancel_until of [state, asg, analysis.backtrack, stats]
            stats.backjumps += 1

            if analysis.assert_lit != 0:
                enqueue_cdcl of [asg, state, analysis.assert_lit, learned_ci, len of state.trail_lim, stats, 1]
            local removed_learnts is reduce_learnt_db of [store, state, stats]
            if removed_learnts > 0:
                if (should_compact_deleted_clauses of [store, state, stats]) != 0:
                    store is compact_deleted_clauses of [nvars, store, state, stats]
            cdcl_maybe_restart of [state, asg, stats]
            continue

        local v is choose_var_cdcl of [asg, state, stats]
        if v == 0:
            return cdcl_result of ["SAT", copy_assignment of asg, stats, state]

        cdcl_push_level of state
        stats.decisions += 1
        local decision_lit is decision_lit_cdcl of [state, v, stats]
        enqueue_cdcl of [asg, state, decision_lit, -1, len of state.trail_lim, stats, 0]

define model_satisfies(nvars, clauses, model) as:
    if model == null:
        return 0
    for clause in clauses:
        if (clause_satisfied of [clause, model]) == 0:
            return 0
    return 1
