        "minimize_steps": stats.minimize_steps
    }

define cdcl_empty_stats() as:
    return {
        "decisions": 0,
        "propagations": 0,
        "conflicts": 0,
        "learnts": 0,
        "backjumps": 0,
        "resolutions": 0,
        "activity_bumps": 0,
        "activity_decays": 0,
        "order_pops": 0,
        "order_inserts": 0,
        "order_skips": 0,
        "clause_allocs": 0,
        "learnt_allocs": 0,
        "learnt_literals": 0,
        "store_clause_copies": 0,
        "store_clause_copy_lits": 0,
        "analysis_rebuilds": 0,
        "analysis_rebuild_lits": 0,
        "analysis_store_scans": 0,
        "analysis_store_lits": 0,
        "analysis_native_learnts": 0,
        "clause_activity_bumps": 0,
        "clause_activity_decays": 0,
        "reduce_runs": 0,
        "reduce_scans": 0,
        "learnt_deleted": 0,
        "learnt_kept_locked": 0,
        "deleted_watch_skips": 0,
        "active_learnts": 0,
        "compact_runs": 0,
        "compact_checks": 0,
        "compact_deferred": 0,
        "compact_pending_deleted": 0,
        "compact_removed": 0,
        "compact_kept": 0,
        "compact_clause_copies": 0,
        "compact_clause_lits": 0,
        "watch_rebuilds": 0,
        "watch_detaches": 0,
        "watch_detach_scans": 0,
        "watch_detach_removed": 0,
        "watch_prunes": 0,
        "watch_prune_scans": 0,
        "watch_prune_removed": 0,
        "compact_replays": 0,
        "restarts": 0,
        "restart_cancels": 0,
        "phase_saves": 0,
        "phase_flips": 0,
