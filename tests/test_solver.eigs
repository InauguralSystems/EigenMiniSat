# ============================================================
# EigenMiniSat solver tests
# ============================================================

load_file of "lib/dimacs.eigs"
load_file of "lib/solver.eigs"
load_file of "lib/bench.eigs"

define assert_eq(label, actual, expected) as:
    if actual != expected:
        print of f"ASSERT {label}: got {actual}, expected {expected}"
        assert of [0, label]
    return 1

define assert_true(label, cond) as:
    if not cond:
        print of f"ASSERT {label}: condition was false"
        assert of [0, label]
    return 1

print of "=== EigenMiniSat solver tests ==="

assert_eq of ["lit encode +1", lit_encode of 1, 0]
assert_eq of ["lit encode -1", lit_encode of -1, 1]
assert_eq of ["lit encode +3", lit_encode of 3, 4]
assert_eq of ["lit encode -3", lit_encode of -3, 5]
assert_eq of ["lit decode 0", lit_decode of 0, 1]
assert_eq of ["lit decode 1", lit_decode of 1, -1]
assert_eq of ["lit decode 4", lit_decode of 4, 3]
assert_eq of ["lit decode 5", lit_decode of 5, -3]
assert_eq of ["lit neg index +3", lit_neg_index of 4, 5]
assert_eq of ["lit neg index -3", lit_neg_index of 5, 4]
assert_eq of ["lit index mirrors encode", lit_index of -2, lit_encode of -2]
watch_slots is make_watch_table of 3
assert_eq of ["watch slots", len of watch_slots, 6]
print of "  MiniSat literal encoding: ok"

assert_eq of ["luby 0", luby_value of 0, 1]
assert_eq of ["luby 1", luby_value of 1, 1]
assert_eq of ["luby 2", luby_value of 2, 2]
assert_eq of ["luby 3", luby_value of 3, 1]
assert_eq of ["luby 4", luby_value of 4, 1]
assert_eq of ["luby 5", luby_value of 5, 2]
assert_eq of ["luby 6", luby_value of 6, 4]
assert_eq of ["luby 7", luby_value of 7, 1]
print of "  Luby restart sequence: ok"

heap_state is {
    "activity": [0, 1, 5, 5],
    "order_heap": [],
    "order_pos": filled_list of [4, -1]
}
order_insert of [heap_state, 1, null]
order_insert of [heap_state, 2, null]
order_insert of [heap_state, 3, null]
assert_eq of ["activity heap first", order_pop_best of [heap_state, null], 2]
assert_eq of ["activity heap tie", order_pop_best of [heap_state, null], 3]
print of "  activity heap: ok"

phase_state is {"phase": [1, -1, 1]}
phase_stats is {"phase_pos_decisions": 0, "phase_neg_decisions": 0}
assert_eq of ["phase negative decision", decision_lit_cdcl of [phase_state, 1, phase_stats], -1]
assert_eq of ["phase positive decision", decision_lit_cdcl of [phase_state, 2, phase_stats], 2]
assert_eq of ["phase negative count", phase_stats.phase_neg_decisions, 1]
assert_eq of ["phase positive count", phase_stats.phase_pos_decisions, 1]
print of "  phase decisions: ok"

phase_case is xor_triangle_case of 1
phase_saved is solve_cnf_cdcl_with_options of [phase_case.nvars, phase_case.clauses, {"phase_policy": "saved"}]
phase_positive is solve_cnf_cdcl_with_options of [phase_case.nvars, phase_case.clauses, {"phase_policy": "positive"}]
phase_negative is solve_cnf_cdcl_with_options of [phase_case.nvars, phase_case.clauses, {"phase_policy": "negative"}]
assert_eq of ["saved phase policy", phase_saved.phase_policy, "saved"]
assert_eq of ["positive phase policy", phase_positive.phase_policy, "positive"]
assert_eq of ["negative phase policy", phase_negative.phase_policy, "negative"]
assert_eq of ["phase saved SAT", phase_saved.status, "SAT"]
assert_eq of ["phase positive SAT", phase_positive.status, "SAT"]
assert_eq of ["phase negative SAT", phase_negative.status, "SAT"]
assert_true of ["saved phase saves", phase_saved.phase_saves > 0]
assert_eq of ["fixed positive no saves", phase_positive.phase_saves, 0]
assert_eq of ["fixed negative no saves", phase_negative.phase_saves, 0]
assert_true of ["fixed negative decisions", phase_negative.phase_neg_decisions > 0]
assert_true of ["fixed negative model", model_satisfies of [phase_case.nvars, phase_case.clauses, phase_negative.model]]
print of "  phase policies: ok"

graph_color_case is complete_graph_color_case of [4, 3]
assert_eq of ["graph color expected", graph_color_case.expected, "UNSAT"]
assert_eq of ["graph color vars", graph_color_case.nvars, 12]
assert_eq of ["graph color clauses", len of graph_color_case.clauses, 34]
graph_color_result is solve_cnf_cdcl_with_options of [graph_color_case.nvars, graph_color_case.clauses, {"restart_policy": "luby", "restart_first": 2, "phase_policy": "negative"}]
assert_eq of ["graph color cdcl UNSAT", graph_color_result.status, "UNSAT"]
assert_true of ["graph color conflicts", graph_color_result.conflicts > 0]
heuristic_cases is heuristic_pressure_cases of 1
heuristic_policies is heuristic_policy_options of null
assert_eq of ["heuristic case count", len of heuristic_cases, 3]
assert_eq of ["heuristic policy count", len of heuristic_policies, 5]
heuristic_phase_case is xor_triangle_case of 1
for heuristic_policy in heuristic_policies:
    heuristic_result is solve_cnf_cdcl_with_options of [heuristic_phase_case.nvars, heuristic_phase_case.clauses, {
        "restart_policy": heuristic_policy.restart_policy,
        "restart_first": heuristic_policy.restart_first,
        "restart_growth": heuristic_policy.restart_growth,
        "phase_policy": heuristic_policy.phase_policy
    }]
    assert_eq of [f"heuristic policy SAT {heuristic_policy.name}", heuristic_result.status, "SAT"]
    assert_true of [f"heuristic policy model {heuristic_policy.name}", model_satisfies of [heuristic_phase_case.nvars, heuristic_phase_case.clauses, heuristic_result.model]]
print of "  heuristic stress helpers: ok"

reduce_state is {
    "clause_learnt": [0, 1, 1, 1],
    "clause_deleted": [0, 0, 0, 0],
    "clause_activity": [0, 0.1, 5, 0.2],
    "clause_lbd": [1, 2, 2, 2],
    "reason": [-1, -1, -1],
    "learnt_limit": 1
}
reduce_stats is {
    "active_learnts": 0,
    "reduce_runs": 0,
    "reduce_scans": 0,
    "learnt_deleted": 0,
    "learnt_kept_locked": 0,
    "watch_rebuilds": 0,
    "compact_replays": 0,
    "compact_runs": 0,
    "compact_removed": 0,
    "compact_kept": 0
}
reduce_clauses is [[1], [1, 2, 3], [1, 0 - 2, 4], [2, 3, 4]]
reduce_store is clause_store_from_clauses of reduce_clauses
assert_eq of ["learnt reduce deletes one", reduce_learnt_db of [reduce_store, reduce_state, reduce_stats], 1]
assert_eq of ["learnt reduce low activity", reduce_state.clause_deleted[1], 1]
assert_eq of ["learnt reduce active count", reduce_stats.active_learnts, 2]
reduce_state.watches is []
reduce_state.watch_a is []
reduce_state.watch_b is []
reduce_state.qhead is 0
reduce_state.trail is []
reduce_state.conflict is -1
compact_store is compact_deleted_clauses of [4, reduce_store, reduce_state, reduce_stats]
assert_eq of ["learnt compact removes", clause_store_len of compact_store, 3]
assert_eq of ["learnt compact metadata", len of reduce_state.clause_learnt, 3]
assert_eq of ["learnt compact runs", reduce_stats.compact_runs, 1]
metadata_churn_test is run_metadata_churn_case of [{
    "name": "metadata-churn-test",
    "nvars": 8,
    "waves": 2,
    "wave_learnts": 12,
    "width": 4,
    "pin_count": 2
}, 0]
assert_eq of ["metadata churn waves", metadata_churn_test.waves, 2]
assert_eq of ["metadata churn learnts", metadata_churn_test.learnts_added, 24]
assert_eq of ["metadata churn clause allocs", metadata_churn_test.clause_allocs, 32]
assert_true of ["metadata churn deleted", metadata_churn_test.learnt_deleted > 0]
assert_true of ["metadata churn compacts", metadata_churn_test.compact_runs > 0]
assert_true of ["metadata churn watch rebuilds", metadata_churn_test.watch_rebuilds > 0]
assert_true of ["metadata churn locked kept", metadata_churn_test.locked_kept > 0]
assert_true of ["metadata churn reason refs", metadata_churn_test.reason_active > 0]
print of "  learnt database reduction: ok"

storage_case is wide_clause_case of [8, 4, 5]
storage_arena is flat_clause_arena of storage_case.clauses
storage_list_summary is clause_list_summary of storage_case.clauses
storage_flat_summary is flat_clause_summary of storage_arena
storage_adapter_summary is clause_store_adapter_summary of storage_arena
assert_eq of ["storage arena offsets", len of storage_arena.offsets, len of storage_case.clauses]
assert_eq of ["storage arena lits", storage_flat_summary.lits, storage_list_summary.lits]
assert_eq of ["storage arena checksum", storage_flat_summary.checksum, storage_list_summary.checksum]
assert_eq of ["storage adapter len", clause_store_len of storage_arena, len of storage_case.clauses]
assert_eq of ["storage adapter size", clause_store_size of [storage_arena, 0], len of storage_case.clauses[0]]
assert_eq of ["storage adapter first lit", clause_store_lit of [storage_arena, 0, 0], storage_case.clauses[0][0]]
assert_eq of ["storage adapter lits", storage_adapter_summary.lits, storage_list_summary.lits]
assert_eq of ["storage adapter checksum", storage_adapter_summary.checksum, storage_list_summary.checksum]
storage_rebuilt is reconstruct_flat_clauses of storage_arena
assert_clauses_match of ["storage arena rebuild", storage_case.clauses, storage_rebuilt]
storage_adapter_rebuilt is clause_store_reconstruct of storage_arena
assert_clauses_match of ["storage adapter rebuild", storage_case.clauses, storage_adapter_rebuilt]
storage_watch_summary is flat_watch_seed_summary of [storage_case.nvars, storage_arena]
assert_true of ["storage arena watch links", storage_watch_summary.links > 0]
assert_true of ["storage arena watch buckets", storage_watch_summary.occupied > 0]
storage_adapter_watch is clause_store_seed_watches of [storage_case.nvars, storage_arena]
assert_eq of ["storage adapter watch links", storage_adapter_watch.links, storage_watch_summary.links]
assert_eq of ["storage adapter watch a", len of storage_adapter_watch.watch_a, len of storage_case.clauses]
assert_eq of ["storage adapter watch b", len of storage_adapter_watch.watch_b, len of storage_case.clauses]
storage_delete is storage_delete_mask of (len of storage_case.clauses)
storage_list_compact is compact_list_clauses_by_mask of [storage_case.clauses, storage_delete.mask]
storage_flat_compact is compact_flat_clause_arena of [storage_arena, storage_delete.mask]
storage_adapter_compact is clause_store_compact_by_mask of [storage_arena, storage_delete.mask]
assert_eq of ["storage compact removed", storage_flat_compact.removed, storage_list_compact.removed]
assert_eq of ["storage compact kept", storage_flat_compact.kept, storage_list_compact.kept]
assert_eq of ["storage adapter compact removed", storage_adapter_compact.removed, storage_list_compact.removed]
assert_eq of ["storage adapter compact kept", storage_adapter_compact.kept, storage_list_compact.kept]
storage_compact_rebuilt is reconstruct_flat_clauses of storage_flat_compact
assert_clauses_match of ["storage compact rebuild", storage_list_compact.clauses, storage_compact_rebuilt]
storage_adapter_compact_rebuilt is clause_store_reconstruct of storage_adapter_compact
assert_clauses_match of ["storage adapter compact rebuild", storage_list_compact.clauses, storage_adapter_compact_rebuilt]
storage_refs is storage_reason_refs of (len of storage_case.clauses)
storage_remapped_refs is remap_reason_refs of [storage_flat_compact.mapping, storage_refs]
storage_ref_summary is ref_list_summary of storage_remapped_refs
assert_true of ["storage remap refs", storage_ref_summary.active > 0]
print of "  flat clause arena helpers: ok"

simple is parse_dimacs_file of "tests/fixtures/simple_sat.cnf"
assert_eq of ["simple nvars", simple.nvars, 3]
assert_eq of ["simple clauses", len of simple.clauses, 3]
simple_result is solve_cnf of [simple.nvars, simple.clauses]
assert_eq of ["simple SAT", simple_result.status, "SAT"]
assert_true of ["simple model satisfies", model_satisfies of [simple.nvars, simple.clauses, simple_result.model]]
simple_watched is solve_cnf_watched of [simple.nvars, simple.clauses]
assert_eq of ["simple watched SAT", simple_watched.status, "SAT"]
assert_true of ["simple watched model satisfies", model_satisfies of [simple.nvars, simple.clauses, simple_watched.model]]
simple_persistent is solve_cnf_persistent of [simple.nvars, simple.clauses]
assert_eq of ["simple persistent SAT", simple_persistent.status, "SAT"]
assert_true of ["simple persistent model satisfies", model_satisfies of [simple.nvars, simple.clauses, simple_persistent.model]]
simple_cdcl is solve_cnf_cdcl of [simple.nvars, simple.clauses]
assert_eq of ["simple cdcl SAT", simple_cdcl.status, "SAT"]
assert_true of ["simple cdcl model satisfies", model_satisfies of [simple.nvars, simple.clauses, simple_cdcl.model]]
print of "  simple SAT: ok"

unit_unsat is parse_dimacs_file of "tests/fixtures/unit_unsat.cnf"
unit_result is solve_cnf of [unit_unsat.nvars, unit_unsat.clauses]
assert_eq of ["unit UNSAT", unit_result.status, "UNSAT"]
assert_true of ["unit conflict counted", unit_result.conflicts > 0]
unit_watched is solve_cnf_watched of [unit_unsat.nvars, unit_unsat.clauses]
assert_eq of ["unit watched UNSAT", unit_watched.status, "UNSAT"]
unit_persistent is solve_cnf_persistent of [unit_unsat.nvars, unit_unsat.clauses]
assert_eq of ["unit persistent UNSAT", unit_persistent.status, "UNSAT"]
unit_cdcl is solve_cnf_cdcl of [unit_unsat.nvars, unit_unsat.clauses]
assert_eq of ["unit cdcl UNSAT", unit_cdcl.status, "UNSAT"]
print of "  unit UNSAT: ok"

php is parse_dimacs_file of "tests/fixtures/pigeonhole_3_2.cnf"
php_result is solve_cnf of [php.nvars, php.clauses]
assert_eq of ["pigeonhole UNSAT", php_result.status, "UNSAT"]
php_watched is solve_cnf_watched of [php.nvars, php.clauses]
assert_eq of ["pigeonhole watched UNSAT", php_watched.status, "UNSAT"]
php_persistent is solve_cnf_persistent of [php.nvars, php.clauses]
assert_eq of ["pigeonhole persistent UNSAT", php_persistent.status, "UNSAT"]
php_cdcl is solve_cnf_cdcl of [php.nvars, php.clauses]
assert_eq of ["pigeonhole cdcl UNSAT", php_cdcl.status, "UNSAT"]
assert_true of ["pigeonhole cdcl learns", php_cdcl.learnts > 0]
assert_true of ["pigeonhole cdcl bumps", php_cdcl.activity_bumps > 0]
assert_true of ["pigeonhole cdcl heap pops", php_cdcl.order_pops > 0]
assert_true of ["pigeonhole cdcl heap reinserts", php_cdcl.order_inserts > 0]
assert_true of ["pigeonhole cdcl clause allocs", php_cdcl.clause_allocs >= (len of php.clauses)]
assert_eq of ["pigeonhole cdcl learnt allocs", php_cdcl.learnt_allocs, php_cdcl.learnts]
assert_true of ["pigeonhole cdcl clause bumps", php_cdcl.clause_activity_bumps > 0]
print of "  pigeonhole UNSAT: ok"

php4 is pigeonhole_case of [4, 3]
php4_cdcl is solve_cnf_cdcl of [php4.nvars, php4.clauses]
assert_eq of ["pigeonhole 4-3 cdcl UNSAT", php4_cdcl.status, "UNSAT"]
assert_eq of ["pigeonhole 4-3 default restart policy", php4_cdcl.restart_policy, "geometric"]
assert_true of ["pigeonhole 4-3 restarts", php4_cdcl.restarts > 0]
assert_eq of ["pigeonhole 4-3 restart index", php4_cdcl.restart_index, php4_cdcl.restarts]
assert_true of ["pigeonhole 4-3 restart cancels", php4_cdcl.restart_cancels > 0]
assert_true of ["pigeonhole 4-3 phase saves", php4_cdcl.phase_saves > 0]
assert_true of ["pigeonhole 4-3 compacts", php4_cdcl.compact_runs > 0]
assert_true of ["pigeonhole 4-3 watch rebuilds", php4_cdcl.watch_rebuilds > 0]
php4_luby is solve_cnf_cdcl_with_options of [php4.nvars, php4.clauses, {"restart_policy": "luby", "restart_first": 1}]
assert_eq of ["pigeonhole 4-3 luby UNSAT", php4_luby.status, "UNSAT"]
assert_eq of ["pigeonhole 4-3 luby policy", php4_luby.restart_policy, "luby"]
assert_true of ["pigeonhole 4-3 luby restarts", php4_luby.restarts > 0]
assert_eq of ["pigeonhole 4-3 luby restart index", php4_luby.restart_index, php4_luby.restarts]
print of "  restart policies: ok"

grid_case is grid_implication_case of [4, 4, 1]
grid_text is case_to_dimacs_text of grid_case
grid_parsed is parse_dimacs_text of grid_text
grid_scan_parsed is parse_dimacs_text_scan of grid_text
grid_ints_parsed is parse_dimacs_text_ints of grid_text
assert_dimacs_same of ["grid scan parser", grid_parsed, grid_scan_parsed]
assert_dimacs_same of ["grid ints parser", grid_parsed, grid_ints_parsed]
assert_eq of ["grid DIMACS vars", grid_parsed.nvars, grid_case.nvars]
assert_eq of ["grid DIMACS clauses", len of grid_parsed.clauses, len of grid_case.clauses]
assert_eq of ["grid DIMACS diagnostics", grid_parsed.ok, 1]
grid_cdcl is solve_cnf_cdcl of [grid_parsed.nvars, grid_parsed.clauses]
assert_eq of ["grid parsed cdcl UNSAT", grid_cdcl.status, "UNSAT"]
grid_path is mktemp of null
assert_true of ["grid mktemp path", (len of grid_path) > 0]
assert_eq of ["grid write DIMACS file", write_text of [grid_path, grid_text], 1]
grid_file_parsed is parse_dimacs_file of grid_path
grid_file_scan_parsed is parse_dimacs_file_scan of grid_path
grid_file_ints_parsed is parse_dimacs_file_ints of grid_path
assert_dimacs_same of ["grid file scan parser", grid_file_parsed, grid_file_scan_parsed]
assert_dimacs_same of ["grid file ints parser", grid_file_parsed, grid_file_ints_parsed]
assert_eq of ["grid file DIMACS vars", grid_file_parsed.nvars, grid_case.nvars]
assert_eq of ["grid file DIMACS clauses", len of grid_file_parsed.clauses, len of grid_case.clauses]
assert_eq of ["grid file DIMACS diagnostics", grid_file_parsed.ok, 1]
assert_eq of ["grid rm DIMACS file", rm of grid_path, 1]

wide_case is wide_clause_case of [18, 6, 7]
wide_text is case_to_dimacs_text of wide_case
wide_parsed is parse_dimacs_text of wide_text
wide_scan_parsed is parse_dimacs_text_scan of wide_text
wide_ints_parsed is parse_dimacs_text_ints of wide_text
assert_dimacs_same of ["wide scan parser", wide_parsed, wide_scan_parsed]
assert_dimacs_same of ["wide ints parser", wide_parsed, wide_ints_parsed]
assert_eq of ["wide DIMACS vars", wide_parsed.nvars, wide_case.nvars]
assert_eq of ["wide DIMACS clauses", len of wide_parsed.clauses, len of wide_case.clauses]
assert_eq of ["wide DIMACS diagnostics", wide_parsed.ok, 1]
wide_cdcl is solve_cnf_cdcl of [wide_parsed.nvars, wide_parsed.clauses]
assert_eq of ["wide parsed cdcl SAT", wide_cdcl.status, "SAT"]
print of "  generated DIMACS fixtures: ok"

bad_count is parse_dimacs_text of "p cnf 1 2\n1 0\n"
bad_count_scan is parse_dimacs_text_scan of "p cnf 1 2\n1 0\n"
bad_count_ints is parse_dimacs_text_ints of "p cnf 1 2\n1 0\n"
assert_dimacs_same of ["bad count scan parser", bad_count, bad_count_scan]
assert_dimacs_same of ["bad count ints parser", bad_count, bad_count_ints]
assert_eq of ["bad count diagnostics", bad_count.ok, 0]
assert_eq of ["bad count flag", bad_count.clause_count_ok, 0]
assert_true of ["bad count message", contains of [bad_count.errors[0], "declared_clauses=2"]]

bad_var is parse_dimacs_text of "p cnf 1 1\n2 0\n"
bad_var_scan is parse_dimacs_text_scan of "p cnf 1 1\n2 0\n"
