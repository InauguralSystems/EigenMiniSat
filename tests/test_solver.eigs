manifest_entry is parse_corpus_manifest_line of ["toy|tests/fixtures/simple_sat.cnf|SAT|3|3|fixture", 1]
assert_eq of ["manifest entry name", manifest_entry.name, "toy"]
assert_eq of ["manifest entry expected", manifest_entry.expected, "SAT"]
assert_eq of ["manifest entry vars", manifest_entry.nvars, 3]
assert_eq of ["manifest entry clauses", manifest_entry.nclauses, 3]
assert_eq of ["manifest entry family", manifest_entry.family, "fixture"]
manifest_comment is parse_corpus_manifest_line of ["# comment", 2]
assert_true of ["manifest comment skipped", manifest_comment == null]
print of "  corpus manifest parser: ok"

corpus_cases is external_corpus_cases of null
assert_true of ["external corpus nonempty", (len of corpus_cases) > 0]
assert_true of ["external corpus expanded", (len of corpus_cases) >= 8]
for corpus in corpus_cases:
    assert_true of [f"corpus file exists {corpus.name}", (file_exists of corpus.path) == 1]
    assert_true of [f"corpus family {corpus.name}", (len of corpus.family) > 0]
    corpus_parsed is parse_dimacs_file of corpus.path
    corpus_scan_parsed is parse_dimacs_file_scan of corpus.path
    corpus_ints_parsed is parse_dimacs_file_ints of corpus.path
    assert_dimacs_same of [f"corpus scan parser {corpus.name}", corpus_parsed, corpus_scan_parsed]
    assert_dimacs_same of [f"corpus ints parser {corpus.name}", corpus_parsed, corpus_ints_parsed]
    assert_eq of [f"corpus vars {corpus.name}", corpus_parsed.nvars, corpus.nvars]
    assert_eq of [f"corpus clauses {corpus.name}", len of corpus_parsed.clauses, corpus.nclauses]
    assert_eq of [f"corpus declared vars {corpus.name}", corpus_parsed.declared_vars, corpus.nvars]
    assert_eq of [f"corpus declared clauses {corpus.name}", corpus_parsed.declared_clauses, corpus.nclauses]
    assert_eq of [f"corpus diagnostics {corpus.name}", corpus_parsed.ok, 1]
    corpus_cdcl is solve_cnf_cdcl of [corpus_parsed.nvars, corpus_parsed.clauses]
    assert_eq of [f"corpus status {corpus.name}", corpus_cdcl.status, corpus.expected]
    if corpus_cdcl.status == "SAT":
        assert_true of [f"corpus model {corpus.name}", model_satisfies of [corpus_parsed.nvars, corpus_parsed.clauses, corpus_cdcl.model]]
print of "  external DIMACS corpus: ok"

chain_sat is chain_case of [12, 0]
chain_sat_result is solve_cnf of [chain_sat.nvars, chain_sat.clauses]
assert_eq of ["chain SAT", chain_sat_result.status, "SAT"]
assert_true of ["chain SAT propagates", chain_sat_result.propagations >= 12]
chain_sat_watched is solve_cnf_watched of [chain_sat.nvars, chain_sat.clauses]
assert_eq of ["chain watched SAT", chain_sat_watched.status, "SAT"]
assert_true of ["chain watched propagates", chain_sat_watched.propagations >= 12]
chain_sat_persistent is solve_cnf_persistent of [chain_sat.nvars, chain_sat.clauses]
assert_eq of ["chain persistent SAT", chain_sat_persistent.status, "SAT"]
assert_true of ["chain persistent propagates", chain_sat_persistent.propagations >= 12]
chain_sat_cdcl is solve_cnf_cdcl of [chain_sat.nvars, chain_sat.clauses]
assert_eq of ["chain cdcl SAT", chain_sat_cdcl.status, "SAT"]
assert_true of ["chain cdcl propagates", chain_sat_cdcl.propagations >= 12]
print of "  generated chain SAT: ok"

chain_unsat is chain_case of [12, 1]
chain_unsat_result is solve_cnf of [chain_unsat.nvars, chain_unsat.clauses]
assert_eq of ["chain UNSAT", chain_unsat_result.status, "UNSAT"]
assert_true of ["chain UNSAT conflict", chain_unsat_result.conflicts > 0]
chain_unsat_watched is solve_cnf_watched of [chain_unsat.nvars, chain_unsat.clauses]
assert_eq of ["chain watched UNSAT", chain_unsat_watched.status, "UNSAT"]
assert_true of ["chain watched UNSAT conflict", chain_unsat_watched.conflicts > 0]
chain_unsat_persistent is solve_cnf_persistent of [chain_unsat.nvars, chain_unsat.clauses]
assert_eq of ["chain persistent UNSAT", chain_unsat_persistent.status, "UNSAT"]
assert_true of ["chain persistent UNSAT conflict", chain_unsat_persistent.conflicts > 0]
chain_unsat_cdcl is solve_cnf_cdcl of [chain_unsat.nvars, chain_unsat.clauses]
assert_eq of ["chain cdcl UNSAT", chain_unsat_cdcl.status, "UNSAT"]
assert_true of ["chain cdcl UNSAT conflict", chain_unsat_cdcl.conflicts > 0]
print of "  generated chain UNSAT: ok"

print of "\n=== All EigenMiniSat solver tests passed ==="
