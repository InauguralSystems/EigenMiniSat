assert_dimacs_same of ["bad var scan parser", bad_var, bad_var_scan]
assert_dimacs_same of ["bad var ints parser", bad_var, bad_var_ints]
assert_eq of ["bad var diagnostics", bad_var.ok, 0]
assert_eq of ["bad var flag", bad_var.var_count_ok, 0]
assert_eq of ["bad var max", bad_var.max_var, 2]
assert_true of ["bad var message", contains of [bad_var.errors[0], "declared_vars=1"]]

bad_token is parse_dimacs_text of "p cnf 1 1\nx 0\n"
